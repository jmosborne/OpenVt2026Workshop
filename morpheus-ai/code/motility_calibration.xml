<?xml version="1.0" encoding="UTF-8"?>
<MorpheusModel version="4">
    <Description>
        <Title>OpenVT Cell Motility Calibration</Title>
        <Details>One isolated CPM cell used to calibrate non-persistent motility.</Details>
    </Description>
    <Global>
        <Constant symbol="target_area_real" value="1"/>
        <Constant symbol="dx" value="1/sqrt(12)"/>
        <Constant symbol="target_area_lattice" value="target_area_real/(dx^2)"/>
        <Constant symbol="cell_diameter_real" value="2*sqrt(target_area_real/pi)"/>
        <Constant symbol="cell_diameter_lattice" value="cell_diameter_real/dx"/>
        <Constant symbol="cell_radius" value="cell_diameter_lattice/2"/>
        <Constant symbol="mcs_duration" value="1"/>
        <Constant symbol="temperature" value="1"/>
        <Constant symbol="area_strength_real" value="43.2"/>
        <Constant symbol="area_strength_lattice" value="area_strength_real*(dx^4)"/>
        <Constant symbol="random_seed" value="0"/>
        <Constant symbol="J_cm_real" value="2*sqrt(12)"/>
        <Constant symbol="J_cm_lattice" value="J_cm_real*dx"/>
    </Global>
    <Space>
        <Lattice class="hexagonal">
            <Neighborhood>
                <Order>optimal</Order>
            </Neighborhood>
            <Size symbol="size" value="200, 232, 0"/>
            <BoundaryConditions>
                <Condition type="constant" boundary="x"/>
                <Condition type="constant" boundary="y"/>
            </BoundaryConditions>
        </Lattice>
        <SpaceSymbol symbol="space"/>
    </Space>
    <Time>
        <StartTime value="0"/>
        <StopTime value="100"/>
        <RandomSeed value="random_seed"/>
        <TimeSymbol symbol="time"/>
    </Time>
    <CellTypes>
        <CellType name="A" class="biological">
            <VolumeConstraint target="target_area_lattice" strength="area_strength_lattice"/>
            <ConnectivityConstraint/>
            <Function symbol="cell_area_cd2">
                <Expression>cell.volume*(dx^2)/(cell_diameter_real^2)</Expression>
            </Function>
            <Function symbol="cell_perimeter_cd">
                <Expression>cell.surface*dx/cell_diameter_real</Expression>
            </Function>
        </CellType>
        <CellType name="medium" class="medium"/>
    </CellTypes>
    <CPM>
        <Interaction default="0">
            <Contact type1="A" type2="A" value="0"/>
            <Contact type1="A" type2="medium" value="J_cm_lattice"/>
        </Interaction>
        <MonteCarloSampler stepper="edgelist">
            <MCSDuration value="mcs_duration"/>
            <Neighborhood>
                <Order>optimal</Order>
            </Neighborhood>
            <MetropolisKinetics temperature="temperature"/>
        </MonteCarloSampler>
        <ShapeSurface scaling="norm">
            <Neighborhood>
                <Order>4</Order>
            </Neighborhood>
        </ShapeSurface>
    </CPM>
    <CellPopulations>
        <Population type="A" size="0">
            <InitCellObjects mode="distance">
                <Arrangement repetitions="1, 1, 1" displacements="1, 1, 1">
                    <Sphere radius="cell_radius" center="size.x/2, sqrt(3)/4*size.y, 0"/>
                </Arrangement>
            </InitCellObjects>
        </Population>
        <BoundaryValue value="medium" boundary="x"/>
        <BoundaryValue value="medium" boundary="-x"/>
        <BoundaryValue value="medium" boundary="y"/>
        <BoundaryValue value="medium" boundary="-y"/>
    </CellPopulations>
    <Analysis>
        <Logger time-step="1" name="calibration_raw">
            <Input>
                <Symbol symbol-ref="cell.center.x"/>
                <Symbol symbol-ref="cell.center.y"/>
                <Symbol symbol-ref="cell_area_cd2"/>
                <Symbol symbol-ref="cell_perimeter_cd"/>
            </Input>
            <Output>
                <TextOutput file-name="calibration_raw" separator="comma"/>
            </Output>
        </Logger>
        <Gnuplotter time-step="100" decorate="false">
            <Terminal name="png"/>
            <Plot title="Calibration cell">
                <Cells flooding="true" value="cell.id"/>
            </Plot>
        </Gnuplotter>
        <ModelGraph include-tags="#untagged" format="dot" reduced="false"/>
    </Analysis>
</MorpheusModel>
